{
  "manifest_version": 3,
  "name": "Tabsolutely",
  "version": "1.0",
  "description": "A highly aesthetic, glassmorphic dashboard organizer for your New Tab.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "bookmarks",
    "history",
    "storage",
    "identity",
    "identity.email",
    "notifications"
  ],
  "host_permissions": [
    "https://get.geojs.io/*",
    "https://api.open-meteo.com/*"
  ],
  "oauth2": {
    "client_id": "296495245180-fg9tevv9i1lbhrohfkcqm4ed4rlphpi5.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  }
}
